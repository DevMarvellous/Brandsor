# Copy to .env.local and fill in. Do NOT commit .env.local.

# --- Google Gemini (brand name generation) ---
GEMINI_API_KEY=
# Optional: a second key dedicated to the AI Brand Starter (brand creation), so a
# burst of anonymous name-generation traffic can't starve it. Falls back to
# GEMINI_API_KEY when unset. Only gives a truly independent quota pool if it's
# from a SEPARATE Google Cloud project — verify in AI Studio; two keys under the
# same project may still share one pool.
GEMINI_API_KEY_STARTER=

# --- Supabase ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: SERVER-ONLY, never expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=
